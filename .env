# Google OAuth client IDs from Google Cloud Console -> APIs & Services -> Credentials.
# The EXPO_PUBLIC_ prefix is required so Expo exposes them to the app at build time.
# Copy this file to ".env" and fill in your own values.

# Web application client ID (also used by Expo Go / web).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# iOS client ID (create an "iOS" OAuth client with your bundle id com.servicemyride.app).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Android client ID (create an "Android" OAuth client with your package com.servicemyride.app
# and the SHA-1 of your signing key).
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=540577682489-8ukvplsncgnrd3c95u0d4abpkr69jv3p.apps.googleusercontent.com
